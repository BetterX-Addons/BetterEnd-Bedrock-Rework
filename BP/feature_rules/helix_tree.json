{
  "format_version": "1.26.0",
  "minecraft:feature_rules": {
    "description": {
      "identifier": "betterend:helix_tree",
      "places_feature": "betterend:helix_tree"
    },
    "conditions": {
      "placement_pass": "surface_pass",
      "minecraft:biome_filter": {
        "test": "has_biome_tag",
        "operator": "==",
        "value": "the_end"
      }
    },
    "distribution": {
      "iterations": "temp.index == 0 ? math.random_integer(0, 1) : 0",
      "x": {
        "distribution": "uniform",
        "extent": [ 0, 15 ]
      },
      "y": "query.heightmap(variable.worldx, variable.worldz)",
      "z": {
        "distribution": "uniform",
        "extent": [ 0, 15 ]
      }
    }
  }
}