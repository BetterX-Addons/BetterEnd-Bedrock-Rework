{
  "format_version": "1.26.0",
  "minecraft:block": {
    "description": {
      "identifier": "betterend:helix_tree_door",
      "menu_category": {
        "category": "construction",
        "group": "minecraft:itemGroup.name.door"
      },
      "states": {
        "betterend:upper_block_bit": [ false, true ],
        "betterend:door_hinge_bit": [ false, true ],
        "betterend:open_bit": [ false, true ]
      },
      "traits": {
        "minecraft:placement_direction": {
          "enabled_states": [ "minecraft:cardinal_direction" ]
        }
      }
    },
    "components": {
      "betterend:door_config": {
        "open_sound": "open.cherry_wood_door",
        "close_sound": "close.cherry_wood_door"
      },
      "minecraft:redstone_consumer": {
        "min_power": 0,
        "propogates_power": false
      },
      "minecraft:flammable": {
        "destroy_chance_modifier": 5,
        "catch_chance_modifier": 5
      },
      "minecraft:destructible_by_mining": {
        "seconds_to_destroy": 1.75
      },
      "minecraft:destructible_by_explosion": {
        "explosion_resistance": 15
      },
      "minecraft:support": {
        "shape": "stair"
      },
      "minecraft:connection_rule": {
        "accepts_connections_from": "none"
      },
      "tag:minecraft:is_axe_item_destructible": {},
      "minecraft:loot": "loot_tables/empty.json",
      "tag:one_way_collidable": {},
      "tag:wood": {}
    },
    "permutations": [
      {
        "condition": "query.block_state('betterend:upper_block_bit')== false",
        "components": {
          "minecraft:geometry": {
            "identifier": "geometry.nb_door",
            "bone_visibility": {
              "open": "query.block_state('betterend:open_bit')== true && query.block_state('betterend:door_hinge_bit')== false",
              "close": "query.block_state('betterend:open_bit')== false && query.block_state('betterend:door_hinge_bit')== false",
              "inverted_open": "query.block_state('betterend:open_bit')== true && query.block_state('betterend:door_hinge_bit')== true",
              "inverted_close": "query.block_state('betterend:open_bit')== false && query.block_state('betterend:door_hinge_bit')== true"
            }
          },
          "minecraft:material_instances": {
            "*": {
              "texture": "betterend:helix_tree_door_bottom",
              "ambient_occlusion": true,
              "face_dimming": true,
              "render_method": "alpha_test_single_sided"
            },
            "up": {
              "texture": "blank",
              "ambient_occlusion": true,
              "face_dimming": true,
              "render_method": "alpha_test_single_sided"
            },
            "hinge": {
              "texture": "betterend:helix_tree_door_bottom",
              "ambient_occlusion": true,
              "face_dimming": true,
              "render_method": "alpha_test_single_sided"
            },
            "bolt": {
              "texture": "betterend:helix_tree_door_side",
              "ambient_occlusion": true,
              "face_dimming": true,
              "render_method": "alpha_test_single_sided"
            }
          }
        }
      },
      {
        "condition": "query.block_state('betterend:upper_block_bit')== true",
        "components": {
          "minecraft:geometry": {
            "identifier": "geometry.nb_door",
            "bone_visibility": {
              "open": "query.block_state('betterend:open_bit')== true && query.block_state('betterend:door_hinge_bit')== false",
              "close": "query.block_state('betterend:open_bit')== false && query.block_state('betterend:door_hinge_bit')== false",
              "inverted_open": "query.block_state('betterend:open_bit')== true && query.block_state('betterend:door_hinge_bit')== true",
              "inverted_close": "query.block_state('betterend:open_bit')== false && query.block_state('betterend:door_hinge_bit')== true"
            }
          },
          "minecraft:material_instances": {
            "*": {
              "texture": "betterend:helix_tree_door_top",
              "ambient_occlusion": true,
              "face_dimming": true,
              "render_method": "alpha_test_single_sided"
            },
            "down": {
              "texture": "blank",
              "ambient_occlusion": true,
              "face_dimming": true,
              "render_method": "alpha_test_single_sided"
            },
            "hinge": {
              "texture": "betterend:helix_tree_door_side",
              "ambient_occlusion": true,
              "face_dimming": true,
              "render_method": "alpha_test_single_sided"
            },
            "bolt": {
              "texture": "betterend:helix_tree_door_side",
              "ambient_occlusion": true,
              "face_dimming": true,
              "render_method": "alpha_test_single_sided"
            },
            "up": {
              "texture": "betterend:helix_tree_door_top",
              "ambient_occlusion": true,
              "face_dimming": true,
              "render_method": "alpha_test_single_sided"
            }
          }
        }
      },
      {
        "condition": "query.block_state('betterend:open_bit')== false",
        "components": {
          "minecraft:selection_box": {
            "origin": [ -8, 0, -8 ],
            "size": [ 16, 16, 3 ]
          },
          "minecraft:collision_box": {
            "origin": [ -8, 0, -8 ],
            "size": [ 16, 16, 3 ]
          }
        }
      },
      {
        "condition": "query.block_state('betterend:open_bit')== true  && query.block_state('betterend:door_hinge_bit')== false",
        "components": {
          "minecraft:selection_box": {
            "origin": [ -8, 0, -8 ],
            "size": [ 3, 16, 16 ]
          },
          "minecraft:collision_box": {
            "origin": [ -8, 0, -8 ],
            "size": [ 3, 16, 16 ]
          }
        }
      },
      {
        "condition": "query.block_state('betterend:open_bit')== true  && query.block_state('betterend:door_hinge_bit')== true",
        "components": {
          "minecraft:selection_box": {
            "origin": [ 5, 0, -8 ],
            "size": [ 3, 16, 16 ]
          },
          "minecraft:collision_box": {
            "origin": [ 5, 0, -8 ],
            "size": [ 3, 16, 16 ]
          }
        }
      },
      {
        "condition": "query.block_state('minecraft:cardinal_direction') == 'north'",
        "components": {
          "minecraft:transformation": {
            "rotation": [ 0, -180, 0 ]
          }
        }
      },
      {
        "condition": "query.block_state('minecraft:cardinal_direction') == 'south'",
        "components": {
          "minecraft:transformation": {
            "rotation": [ 0, 0, 0 ]
          }
        }
      },
      {
        "condition": "query.block_state('minecraft:cardinal_direction') == 'east'",
        "components": {
          "minecraft:transformation": {
            "rotation": [ 0, 90, 0 ]
          }
        }
      },
      {
        "condition": "query.block_state('minecraft:cardinal_direction') == 'west'",
        "components": {
          "minecraft:transformation": {
            "rotation": [ 0, -90, 0 ]
          }
        }
      }
    ]
  }
}