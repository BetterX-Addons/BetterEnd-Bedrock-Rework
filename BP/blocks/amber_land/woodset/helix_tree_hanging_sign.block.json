{
  "format_version": "1.26.0",
  "minecraft:block": {
    "description": {
      "identifier": "betterend:helix_tree_hanging_sign",
      "menu_category": {
        "category": "items",
        "group": "minecraft:itemGroup.name.hanging_sign"
      },
      "traits": {
        "minecraft:placement_position": {
          "enabled_states": [ "minecraft:block_face" ]
        }
      },
      "states": {
        "wiki:rotation": {
          "values": {
            "min": 0,
            "max": 15
          }
        },
        "horizons:fence": [ false, true ]
      }
    },
    "components": {
      "minecraft:collision_box": false,
      "minecraft:selection_box": {
        "origin": [ -6, 0, -6 ],
        "size": [ 12, 16, 12 ]
      },
      "minecraft:geometry": {
        "identifier": "geometry.hanging_sign",
        "bone_visibility": {
          "up_0": "q.block_state('minecraft:block_face') == 'down' && math.mod(q.block_state('wiki:rotation'), 4) == 0",
          "up_0_small_chains": "(q.block_state('minecraft:block_face') == 'down' && math.mod(q.block_state('wiki:rotation'), 4) == 0) && q.block_state('horizons:fence') == false",
          "up_0_chain": "(q.block_state('minecraft:block_face') == 'down' && math.mod(q.block_state('wiki:rotation'), 4) == 0) && q.block_state('horizons:fence') == true",
          "up_22_5": "q.block_state('minecraft:block_face') == 'down' && math.mod(q.block_state('wiki:rotation'), 4) == 1",
          "up_22_5_small_chains": "(q.block_state('minecraft:block_face') == 'down' && math.mod(q.block_state('wiki:rotation'), 4) == 1)  && q.block_state('horizons:fence') == false",
          "up_22_5_chain": "(q.block_state('minecraft:block_face') == 'down' && math.mod(q.block_state('wiki:rotation'), 4) == 1)  && q.block_state('horizons:fence') == true",
          "up_45": "q.block_state('minecraft:block_face') == 'down' && math.mod(q.block_state('wiki:rotation'), 4) == 2",
          "up_45_small_chains": "(q.block_state('minecraft:block_face') == 'down' && math.mod(q.block_state('wiki:rotation'), 4) == 2) && q.block_state('horizons:fence') == false",
          "up_45_chain": "(q.block_state('minecraft:block_face') == 'down' && math.mod(q.block_state('wiki:rotation'), 4) == 2) && q.block_state('horizons:fence') == true",
          "up_67_5": "q.block_state('minecraft:block_face') == 'down' && math.mod(q.block_state('wiki:rotation'), 4) == 3",
          "up_67_5_small_chains": "(q.block_state('minecraft:block_face') == 'down' && math.mod(q.block_state('wiki:rotation'), 4) == 3) && q.block_state('horizons:fence') == false",
          "up_67_5_chain": "(q.block_state('minecraft:block_face') == 'down' && math.mod(q.block_state('wiki:rotation'), 4) == 3) && q.block_state('horizons:fence') == true",
          "side": "q.block_state('minecraft:block_face') != 'down'"
        }
      },
      "minecraft:material_instances": {
        "*": {
          "texture": "betterend:helix_tree_planks",
          "render_method": "alpha_test"
        }
      },
      "minecraft:placement_filter": {
        "conditions": [
          {
            "allowed_faces": [ "down", "side" ]
          }
        ]
      },
      "betterend:hanging_sign_rotation": {},
      "minecraft:flammable": {
        "destroy_chance_modifier": 5,
        "catch_chance_modifier": 5
      },
      "minecraft:destructible_by_mining": {
        "seconds_to_destroy": 1
      },
      "minecraft:destructible_by_explosion": {
        "explosion_resistance": 0
      },
      "minecraft:support": {
        "shape": "stair"
      },
      "minecraft:connection_rule": {
        "accepts_connections_from": "none"
      },
      "tag:minecraft:is_axe_item_destructible": {},
      "tag:wood": {}
    },
    "permutations": [
      {
        "condition": "q.block_state('wiki:rotation') >= 4 || q.block_state('minecraft:block_face') == 'east'",
        "components": {
          "minecraft:transformation": {
            "rotation": [ 0, -90, 0 ]
          }
        }
      },
      {
        "condition": "q.block_state('wiki:rotation') >= 8 || q.block_state('minecraft:block_face') == 'south' || q.block_state('minecraft:block_face') == 'up'",
        "components": {
          "minecraft:transformation": {
            "rotation": [ 0, 180, 0 ]
          }
        }
      },
      {
        "condition": "q.block_state('wiki:rotation') >= 12 || q.block_state('minecraft:block_face') == 'west'",
        "components": {
          "minecraft:transformation": {
            "rotation": [ 0, 90, 0 ]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:block_face') != 'down'",
        "components": {
          "minecraft:selection_box": {
            "origin": [ -2, 0, -8 ],
            "size": [ 4, 16, 16 ]
          },
          "minecraft:collision_box": {
            "origin": [ -2, 14, -8 ],
            "size": [ 4, 2, 16 ]
          }
        }
      }
    ]
  }
}